{
  "name": "student-stipend-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "contracts:build": "cd contracts/student_vesting && cargo build --target wasm32-unknown-unknown --release",
    "contracts:test": "cd contracts/student_vesting && cargo test",
    "contracts:deploy": "bash scripts/deploy-contracts.sh",
    "types:generate": "ts-node scripts/generate-types.ts",
    "test": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@stellar/freighter-api": "^2.1.0",
    "@stellar/stellar-sdk": "^12.2.0",
    "@stellar/soroban-client": "^0.10.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.22.3",
    "lucide-react": "^0.344.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.1",
    "papaparse": "^5.4.1",
    "qrcode.react": "^3.1.0",
    "date-fns": "^3.3.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@types/papaparse": "^5.3.14",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.6",
    "vitest": "^1.3.1",
    "@playwright/test": "^1.42.1",
    "ts-node": "^10.9.2"
  }
}